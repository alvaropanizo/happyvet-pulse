{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://happyvet-pulse/contracts/medical_record.schema.json",
  "title": "MedicalRecordScanEnvelopeContract",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "medical_record",
    "parsing_metadata"
  ],
  "properties": {
    "medical_record": { "$ref": "#/$defs/medicalRecordFinal" },
    "parsing_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine",
        "extraction_method",
        "latency_ms",
        "extracted_char_count",
        "meaningful_text",
        "integrity_score"
      ],
      "properties": {
        "engine": { "type": "string" },
        "extraction_method": { "type": "string", "enum": ["fast_path", "tesseract_fallback"] },
        "latency_ms": { "type": "integer", "minimum": 0 },
        "extracted_char_count": { "type": "integer", "minimum": 0 },
        "meaningful_text": { "type": "boolean" },
        "integrity_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "mapping_coverage_pct": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "mapped_fields_count": { "type": ["integer", "null"], "minimum": 0 },
        "total_fields_count": { "type": ["integer", "null"], "minimum": 0 },
        "confident_fields_count": { "type": ["integer", "null"], "minimum": 0 },
        "confident_total_fields_count": { "type": ["integer", "null"], "minimum": 0 },
        "confident_coverage_pct": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "reason": { "type": ["string", "null"] }
      }
    },
    "processor_version": { "type": ["string", "null"] },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "timings_ms": { "type": ["number", "integer", "null"], "minimum": 0 }
  },
  "$defs": {
    "medicalRecordFinal": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "record_id",
        "source_documents",
        "patient",
        "owner",
        "timeline",
        "review"
      ],
      "properties": {
        "record_id": { "type": "string" },
        "source_documents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "document_id",
              "filename",
              "source_type",
              "raw_text",
              "attachments"
            ],
            "properties": {
              "document_id": { "type": "string" },
              "filename": { "type": "string" },
              "source_type": { "type": "string" },
              "language": { "type": ["string", "null"] },
              "uploaded_at": { "type": ["string", "null"] },
              "raw_text": { "type": "string" },
              "attachments": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": ["attachment_id", "kind", "name"],
                  "properties": {
                    "attachment_id": { "type": "string" },
                    "kind": {
                      "type": "string",
                      "enum": ["pdf_page", "image", "lab_report", "rx", "unknown"]
                    },
                    "name": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "patient": {
          "type": "object",
          "additionalProperties": true,
          "required": ["name", "species", "breed", "sex", "birth_date", "chip_id", "weight_kg"],
          "properties": {
            "name": { "$ref": "#/$defs/fieldValue" },
            "species": { "$ref": "#/$defs/speciesFieldValue" },
            "breed": { "$ref": "#/$defs/fieldValue" },
            "sex": { "$ref": "#/$defs/sexFieldValue" },
            "birth_date": { "$ref": "#/$defs/fieldValue" },
            "chip_id": { "$ref": "#/$defs/fieldValue" },
            "weight_kg": { "$ref": "#/$defs/fieldValue" }
          }
        },
        "owner": {
          "type": "object",
          "additionalProperties": true,
          "required": ["name", "surname", "phone_number", "email"],
          "properties": {
            "name": { "$ref": "#/$defs/fieldValue" },
            "surname": { "$ref": "#/$defs/fieldValue" },
            "phone_number": { "$ref": "#/$defs/fieldValue" },
            "email": { "$ref": "#/$defs/fieldValue" },
            "address": { "anyOf": [{ "$ref": "#/$defs/fieldValue" }, { "type": "null" }] }
          }
        },
        "timeline": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["event_id", "status", "event_type", "date", "clinic", "title"],
            "properties": {
              "event_id": { "type": "string" },
              "status": { "type": "string", "enum": ["needs_review", "approved"] },
              "date": { "type": ["string", "null"] },
              "event_type": {
                "type": "string",
                "enum": [
                  "visit",
                  "lab",
                  "administrative",
                  "vaccination",
                  "phone_call",
                  "hospitalization",
                  "prescription",
                  "problem",
                  "reminder"
                ]
              },
              "clinic": { "type": ["string", "null"] },
              "title": { "type": ["string", "null"] },
              "anamnesis": { "type": ["string", "null"] },
              "assessment": {
                "type": "array",
                "items": { "type": "string" }
              },
              "diagnoses": {
                "type": "array",
                "items": { "$ref": "#/$defs/diagnosis" }
              },
              "treatments": {
                "type": "array",
                "items": { "$ref": "#/$defs/treatment" }
              },
              "tests": {
                "type": "array",
                "items": { "$ref": "#/$defs/testResult" }
              },
              "attachments": {
                "type": "array",
                "items": { "type": "string" }
              },
              "source": {
                "anyOf": [{ "$ref": "#/$defs/eventSource" }, { "type": "null" }]
              }
            }
          }
        },
        "review": {
          "type": "object",
          "additionalProperties": true,
          "required": ["status", "edited_fields", "last_editor", "updated_at"],
          "properties": {
            "status": { "type": "string", "enum": ["needs_review", "in_review", "approved", "automatically_approved"] },
            "edited_fields": {
              "type": "array",
              "items": { "type": "string" }
            },
            "last_editor": { "type": ["string", "null"] },
            "updated_at": { "type": ["string", "null"] }
          }
        }
      }
    },
    "fieldValue": {
      "type": "object",
      "additionalProperties": true,
      "required": ["value", "confidence", "edited", "status"],
      "properties": {
        "value": { "type": ["string", "number", "integer", "null"] },
        "confidence": { "type": "number" },
        "edited": { "type": "boolean" },
        "status": { "type": "string", "enum": ["empty", "pending", "approved", "automatically_approved", "edited"] }
      }
    },
    "speciesFieldValue": {
      "type": "object",
      "additionalProperties": true,
      "required": ["value", "confidence", "edited", "status"],
      "properties": {
        "value": { "type": ["string", "null"], "enum": ["cat", "dog", "bird", "other", null] },
        "confidence": { "type": "number" },
        "edited": { "type": "boolean" },
        "status": { "type": "string", "enum": ["empty", "pending", "approved", "automatically_approved", "edited"] }
      }
    },
    "sexFieldValue": {
      "type": "object",
      "additionalProperties": true,
      "required": ["value", "confidence", "edited", "status"],
      "properties": {
        "value": { "type": ["string", "null"], "enum": ["male", "female", null] },
        "confidence": { "type": "number" },
        "edited": { "type": "boolean" },
        "status": { "type": "string", "enum": ["empty", "pending", "approved", "automatically_approved", "edited"] }
      }
    },
    "diagnosis": {
      "type": "object",
      "additionalProperties": true,
      "required": ["text", "status"],
      "properties": {
        "text": { "type": "string" },
        "status": { "type": "string", "enum": ["confirmed", "suspected", "ruled_out"] }
      }
    },
    "treatment": {
      "type": "object",
      "additionalProperties": true,
      "required": ["medication"],
      "properties": {
        "medication": { "type": "string" },
        "dose": { "type": ["string", "null"] },
        "frequency": { "type": ["string", "null"] },
        "duration": { "type": ["string", "null"] }
      }
    },
    "testResult": {
      "type": "object",
      "additionalProperties": true,
      "required": ["test_name", "values"],
      "properties": {
        "test_name": { "type": "string" },
        "result_summary": { "type": ["string", "null"] },
        "values": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "number", "integer", "null"]
            }
          }
        }
      }
    },
    "eventSource": {
      "type": "object",
      "additionalProperties": true,
      "required": ["document_id"],
      "properties": {
        "document_id": { "type": "string" },
        "span": {
          "anyOf": [{ "$ref": "#/$defs/sourceSpan" }, { "type": "null" }]
        }
      }
    },
    "sourceSpan": {
      "type": "object",
      "additionalProperties": true,
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "integer" },
        "end": { "type": "integer" }
      }
    }
  }
}
